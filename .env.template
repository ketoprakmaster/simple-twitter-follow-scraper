# .env
# Configuration for Twitter Follow Scraper

# --- TWITTER SELECTOR OVERRIDES ---
# Use these only if the scraper breaks due to a Twitter UI update.

# Selector for the profile link/button to get the username
# SELECTOR_ACCOUNT_MENU=a[aria-label='profile' i]

# Selector for each user cell in the followers/following list
# SELECTOR_USER_CELL=button a[tabindex='-1'] span

# Selector for the follower/following count on a profile
# SELECTOR_FOLLOW_COUNT=a[href*='following' i]

# --- SCRAPER SETTINGS ---

# Amount to scroll each time (e.g., 250 = 2.5x page height)
# SCROLL_AMOUNT=250

# Scraping timeout in seconds
# SCRAPE_TIMEOUT=5

# Number of consecutive empty scrolls before stopping
# MAX_EMPTY_SCROLLS=10
